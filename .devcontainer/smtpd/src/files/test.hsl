-----END PUBLIC KEY-----
'']];
smime_sign_encrypt($mail, ["x509" => $cert[0], "privatekey" => $key], ["certs" => [$cert[0]]]);
$encrypted = MailMessage::String($mail->toString());
$result = smime_decrypt($encrypted, ["x509" => $cert[0], "privatekey" => $key], ["store" => [$cert[0]]]);
if ($result["signers"])
    $result["signers"] = array_map(function ($signer) { return X509($signer)->public_key(["pem" => true]); }, $result["signers"]);
if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 10 (Sign + Encrypt): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 10 (Sign + Encrypt):\t\tOK";
